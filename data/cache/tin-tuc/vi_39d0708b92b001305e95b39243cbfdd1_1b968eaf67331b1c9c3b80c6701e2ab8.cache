a:4:{i:0;a:9:{s:2:"id";i:5;s:5:"catid";i:5;s:5:"title";s:46:"Hai cách ướp trà sen thông dụng nhất";s:5:"alias";s:36:"hai-cach-uop-tra-sen-thong-dung-nhat";s:11:"homeimgfile";s:106:"https://vnn-imgs-a1.vgcloud.vn/info-imgs.vgcloud.vn/2020/06/26/14/hai-cach-uop-tra-sen-thong-dung-nhat.jpg";s:12:"homeimgthumb";i:3;s:8:"hometext";s:168:"Nếu như bạn chưa có điều kiện thưởng thức chén trà sen Hồ Tây nổi tiếng thì có thể tự mình học cách ướp trà sen tại nhà nhé.";s:8:"publtime";i:1712670000;s:13:"external_link";i:0;}i:1;a:9:{s:2:"id";i:4;s:5:"catid";i:1;s:5:"title";s:52:"Tuyệt chiêu pha trà ngon cực kỳ đơn giản";s:5:"alias";s:40:"tuyet-chieu-pha-tra-ngon-cuc-ky-don-gian";s:11:"homeimgfile";s:98:"https://cdn.tgdd.vn/Files/2018/01/16/1059355/tuyet-chieu-pha-tra-ngon-cuc-ky-don-gian2_800x400.jpg";s:12:"homeimgthumb";i:3;s:8:"hometext";s:312:"Trà vẫn là thức uống yêu thích của nhiều người nhất là đối với các cụ lớn tuổi. Để có được ly trà ngon, đậm vị còn tùy thuộc và 4 yếu tố: loại trà, ấm pha, nguồn nước và cách pha trà. Vậy phải như thế nào mới có một ấm trà ngon?";s:8:"publtime";i:1712669940;s:13:"external_link";i:0;}i:2;a:9:{s:2:"id";i:3;s:5:"catid";i:3;s:5:"title";s:72:"Hướng dẫn cách pha trà thơm – ngon – giữ nguyên vị trà";s:5:"alias";s:50:"huong-dan-cach-pha-tra-thom-ngon-giu-nguyen-vi-tra";s:11:"homeimgfile";s:74:"https://www.tita.art/wp-content/uploads/2023/06/cach-pha-tra-dung-cach.jpg";s:12:"homeimgthumb";i:3;s:8:"hometext";s:467:"Hầu như ai cũng biết đến cách pha trà cơ bản là hãm lá trà khô trong ấm với nước sôi rồi rót ra chén để thưởng thức. Tuy nhiên để có được một chén trà thơm, ngon, giữ trọn hương vị tự nhiên nhất thì bạn cần phải chú ý đến một số yếu tố ảnh hưởng khác. Vậy làm thế nào để pha trà đúng cách, mời bạn cùng TITA Art tìm hiểu trong bài viết sau đây nhé.";s:8:"publtime";i:1712669880;s:13:"external_link";i:0;}i:3;a:9:{s:2:"id";i:2;s:5:"catid";i:1;s:5:"title";s:79:"Thưởng thức Trà Sen Sớm để cảm nhận hương vị sớm của Sen";s:5:"alias";s:56:"thuong-thuc-tra-sen-som-de-cam-nhan-huong-vi-som-cua-sen";s:11:"homeimgfile";s:76:"https://htxtravandung.vn/uploads/news/tin_hoat_dong/pha-tra-sen-tay-ho-1.jpg";s:12:"homeimgthumb";i:3;s:8:"hometext";s:502:"Sớm mai lấp ló vài giọt nắng. Giữa khoảng không gian mênh mông, làn sương mỏng manh đang tan đi trong mùi sen thơm nức… 5h sáng, mấy chiếc ghe bắt đầu vào việc. Đôi mắt tinh nhanh của người hái sen tìm kiếm những búp sen “hé miệng sáo” đang lấp ló giấu mình sau những tấm lá. Và rồi chính họ cũng thoắt ẩn thoắt hiện trong đầm sen mênh mông. Chỉ biết là trước khi nắng lên thì ghe đã cập";s:8:"publtime";i:1712669700;s:13:"external_link";i:0;}}